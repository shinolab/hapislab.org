import { Image } from 'astro:assets';
import type { TopicSummary } from '../data/site';
import { withBasePath } from '../lib/urls';

interface Props {
	topics: TopicSummary[];
	locale?: 'ja' | 'en';
}

const { topics, locale = 'ja' } = Astro.props;
const topicEntries = topics.map((topic) => ({
	topic,
	imageSrc: topic.image,
}));
---

<section class="content-section">
	<div class="legacy-topic-grid">
		{topicEntries.map(({ topic, imageSrc }) => (
			<article class="topic-card topic-card--legacy">
				{
					(locale === 'en' ? topic.detailPathEn || topic.detailPath : topic.detailPath) ? (
						<a
							class="topic-card__link"
							href={withBasePath(locale === 'en' ? topic.detailPathEn || topic.detailPath : topic.detailPath)}
						>
							<Image
								src={imageSrc}
								alt={topic.imageAlt ?? topic.title}
								class="topic-card__image"
								width={400}
								height={300}
							/>
							<h3>{topic.title}</h3>
						</a>
					) : (
						<Fragment>
							<Image
								src={imageSrc}
								alt={topic.imageAlt ?? topic.title}
								class="topic-card__image"
								width={400}
								height={300}
							/>
							<h3>{topic.title}</h3>
						</Fragment>
