	description={description}
	lead={lead}
	currentPath={`/members/${memberSlug}`}
	eyebrow="メンバー"
	ContentComponent={content.ContentComponent}
	htmlContent={content.htmlContent}
	languageSwitchHref={`/en/members/${memberSlug}`}
/>
</file>

