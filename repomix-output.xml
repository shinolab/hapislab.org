<file path="src/components/ResearchTopicArticle.astro">
---
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import type { ResearchTopicListItem } from "../lib/research-topics";
import { withBasePath } from "../lib/urls";

interface Props {
	topic: ResearchTopicListItem;
	title: string;
	description: string;
	currentPath: string;
	locale?: "ja" | "en";
	languageSwitchHref?: string;
	ContentComponent?: AstroComponentFactory;
	htmlContent?: string;
	fallbackNotice?: string;
	previousTopic?: ResearchTopicListItem;
	nextTopic?: ResearchTopicListItem;
	relatedTopics: ResearchTopicListItem[];
	shareUrl: string;
}

const {
	topic,
	title,
	description,
	currentPath,
	locale = "ja",
	languageSwitchHref,
	ContentComponent,
	htmlContent = "",
	fallbackNotice,
	previousTopic,
	nextTopic,
	relatedTopics,
	shareUrl,
} = Astro.props;

const articleDate = topic.date ?? topic.updated ?? "";
const dateObject = articleDate ? new Date(articleDate) : undefined;
const articleYear =
	dateObject && !Number.isNaN(dateObject.getTime())
		? String(dateObject.getFullYear())
		: "";
const articleMonthDay =
	dateObject && !Number.isNaN(dateObject.getTime())
		? `${dateObject.getMonth() + 1}/${dateObject.getDate()}`
		: "";

const publishedLabel = locale === "en" ? "Published: " : "公開日: ";
const updatedLabel = locale === "en" ? "Updated: " : "更新日: ";
const relatedHeading = locale === "en" ? "Related topics" : "関連記事";
const previousLabel = locale === "en" ? "Previous article" : "前の記事";
const nextLabel = locale === "en" ? "Next article" : "次の記事";
const copyLabel = locale === "en" ? "Copy URL" : "URLをコピー";
const pageTitle = `${title} | ${locale === "en" ? "Shinoda & Makino Lab" : "篠田・牧野研究室"}`;
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(shareUrl);
const shareLinks = [
	{
		label: "X",
		href: `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`,
		className: "topic-article-share__link topic-article-share__link--x",
	},
	{
		label: "Facebook",
		href: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
		className:
			"topic-article-share__link topic-article-share__link--facebook",
	},
	{
		label: "Hatena",
		href: `https://b.hatena.ne.jp/entry/${shareUrl.replace(/^https?:\/\//, "")}`,
		className:
			"topic-article-share__link topic-article-share__link--hatena",
	},
	{
		label: "Pocket",
		href: `https://getpocket.com/edit?url=${encodedUrl}&title=${encodedTitle}`,
		className:
			"topic-article-share__link topic-article-share__link--pocket",
	},
	{
		label: "LINE",
		href: `https://social-plugins.line.me/lineit/share?url=${encodedUrl}`,
		className: "topic-article-share__link topic-article-share__link--line",
	},
];
const relatedTopicsWithAssets = relatedTopics.map((relatedTopic) => ({
	topic: relatedTopic,
	imageSrc: relatedTopic.image,
}));
---

<Layout
	title={pageTitle}
	description={description}
	currentPath={currentPath}
	locale={locale}
	languageSwitchHref={languageSwitchHref}
>
	<head>
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/katex.min.css"
			integrity="sha384-/L6i+LN3dyoaK2jYG5ZLh5u13cjdsPDcFOSNJeFBFa/KgVXR5kOfTdiN3ft1uMAq"
			crossorigin="anonymous"
		/>
	</head>

	<div class="page-shell page-shell--research-topic-article">
		<section class="topic-article-hero">
			<div class="container topic-article-hero__inner">
				<div class="topic-article-hero__date" aria-hidden="true">
					{
						articleYear && (
							<span class="topic-article-hero__year">
								{articleYear}
							</span>
						)
					}
					{
						articleMonthDay && (
							<span class="topic-article-hero__month-day">
								{articleMonthDay}
							</span>
						)
					}
				</div>

				<div class="topic-article-hero__body">
					<h1>{title}</h1>
				</div>
			</div>
		</section>

		<main class="container page-main topic-article-main">
			<div class="content-stack topic-article-stack">
				{
					fallbackNotice && (
						<aside class="surface notice-card" role="note">
							<p>{fallbackNotice}</p>
						</aside>
					)
				}

				<article class="prose topic-article-content">
					{
						ContentComponent ? (
							<ContentComponent />
						) : (
							<Fragment set:html={htmlContent} />
						)
					}
				</article>

				<p class="topic-article-content-meta">
					<span>{publishedLabel}</span>
					<span
						>{
							topic.date ??
								(locale === "en" ? "Not set" : "未設定")
						}</span
					>
					<span class="topic-article-content-meta__separator">/</span>
					<span>{updatedLabel}</span>
					<span>
						{
							topic.updated ??
								topic.date ??
								(locale === "en" ? "Not set" : "未設定")
						}
					</span>
				</p>

				<section
					class="topic-article-share"
					aria-labelledby="topic-share-heading"
				>
					<div class="topic-article-share__actions">
						{
							shareLinks.map((item) => (
								<a
									class={item.className}
									href={item.href}
									target="_blank"
									rel="noreferrer"
								>
									{item.label}
								</a>
							))
						}

						<button
							type="button"
							class="topic-article-share__link topic-article-share__link--copy"
							data-copy-url={shareUrl}
							data-copy-default={copyLabel}
							data-copy-success={locale === "en"
								? "Copied"
								: "コピーしました"}
						>
							{copyLabel}
						</button>
					</div>
				</section>

				{
					(previousTopic || nextTopic) && (
						<nav
							class="topic-article-pagination"
							aria-label={
								locale === "en"
									? "Article navigation"
									: "記事ナビゲーション"
							}
						>
							{previousTopic ? (
								<a
									class="topic-article-pagination__item"
									href={withBasePath(
										(locale === "en"
											? previousTopic.detailPathEn
											: previousTopic.detailPath) ?? "#",
									)}
								>
									<span class="topic-article-pagination__label">
										{previousLabel}
									</span>
									<strong>
										{previousTopic.title}
									</strong>
								</a>
							) : (
								<div />
							)}

							{nextTopic ? (
								<a
									class="topic-article-pagination__item topic-article-pagination__item--next"
									href={withBasePath(
										(locale === "en"
											? nextTopic.detailPathEn
											: nextTopic.detailPath) ?? "#",
									)}
								>
									<span class="topic-article-pagination__label">
										{nextLabel}
									</span>
									<strong>
										{nextTopic.title}
									</strong>
								</a>
							) : (
								<div />
							)}
						</nav>
					)
				}

				<section
					class="topic-article-related"
					aria-labelledby="topic-related-heading"
				>
					<div class="section-heading section-heading--legacy">
						<h2 id="topic-related-heading">{relatedHeading}</h2>
					</div>

					<div class="legacy-topic-grid topic-article-related__grid">
						{
							relatedTopicsWithAssets.map(
								({ topic: relatedTopic, imageSrc }) => (
									<article class="topic-card topic-card--legacy">
										<a
											class="topic-card__link"
											href={withBasePath(
												(locale === "en"
													? relatedTopic.detailPathEn
													: relatedTopic.detailPath) ??
													"#",
											)}
										>
											<Image
												class="topic-card__image"
												src={imageSrc}
												alt={
													relatedTopic.imageAlt ??
													relatedTopic.title
												}
												loading="lazy"
												width={400}
												height={300}
											/>

											<p class="topic-card__date">
												{relatedTopic.date}
											</p>
											<h3>
												{relatedTopic.title}
											</h3>
										</a>
									</article>
								),
							)
						}
					</div>
				</section>
			</div>
		</main>
	</div>
</Layout>

<script>
	document
		.querySelectorAll<HTMLButtonElement>("[data-copy-url]")
		.forEach((button) => {
			button.addEventListener("click", async () => {
				const copyUrl = button.dataset.copyUrl;
				if (!copyUrl) return;

				await navigator.clipboard.writeText(copyUrl);
				button.textContent =
					button.dataset.copySuccess ?? button.textContent;

				window.setTimeout(() => {
					button.textContent =
						button.dataset.copyDefault ?? button.textContent;
				}, 1600);
			});
		});
</script>
</file>

<file path="src/content/research-topics/ultrasound-fragrance-rendering.md">
---
title: 超音波ベッセルビームによる空中匂い輸送
titleEn: Midair Ultrasound Fragrance Rendering
summary: 空中に超音波による「音響ベッセルビーム」を形成し、これに伴って発生する空気の流れ（音響流）により、環境中の匂いの空中運搬を行う技術を開発しました。
date: '2017-11-01'
updated: '2023-03-31'
thumbnail: /assets/research-topics/ultrasound-fragrance-rendering/hero.jpg
thumbnailAlt: 超音波ベッセルビームによる空中匂い輸送
---

![超音波ベッセルビームによる空中匂い輸送](../../assets/research-topics/ultrasound-fragrance-rendering/hero.jpg)

空中に超音波による「音響ベッセルビーム」を形成し、これに伴って発生する空気の流れ（音響流）により、環境中の匂いの空中運搬を行う技術を開発しました。
超音波のビームにより生成される気流は装置の遠方であっても狭い断面積を維持することができ、これにより局在的なにおいの提示を可能にしています。
匂いを発する物体は特定の容器に格納しなければならないといった制約なく、装置とは独立に自由に配置することができます。テーブルに置かれたカップに入ったコーヒーなどの生活空間における通常の物体に本技術は適用できます。
装置の配置の仕方によっては、ユーザーの鼻の近くにある物体のにおいを吹き飛ばすことで、匂いの除去を行うことも可能です。
本技術はあらかじめ用意された匂いの提示を行うだけでなく、ユーザーを取り巻く匂いの環境を制御することを可能にします。

[論文：Keisuke Hasegawa, Liwei Qiu, Akihito Noda, Seki Inoue, Hiroyuki Shinoda, “Electronically Steerable Ultrasound-Driven Narrow and Long Air Stream”, Applied Physics Letters, **111**, 064104 (2017)　（APL’s Editor’s Pickに選定）](http://aip.scitation.org/doi/10.1063/1.4985159)

[上記論文に関するweb記事: https://phys.org/news/2017-08-scientists-airflow-mid-air.html](https://phys.org/news/2017-08-scientists-airflow-mid-air.html)

[SIGGRAPH ASIA 2017で展示予定：紹介ページ](https://sa2017.siggraph.org/attendees/emerging-technologies?view=event&eid=113)
</file>

<file path="src/content/research-topics/volleyball-trajectory-prediction.md">
---
title: トス動作の機械学習に基づくバレーボールの球軌跡予測
titleEn: Prediction of Volleyball Trajectory Using Skeletal Motions of Setter Player
summary: バレーボールのセッターの身体動作を基に，ニューラルネットワークを用いて，セッターが上げたトスの，0.3秒先のボールの2次元的な位置を予測するシステムを開発しました．
date: '2019-03-01'
updated: '2023-03-31'
thumbnail: /assets/research-topics/volleyball-trajectory-prediction/thumbnail.png
thumbnailAlt: トス動作の機械学習に基づくバレーボールの球軌跡予測
---

バレーボールのセッターの身体動作を基に，ニューラルネットワークを用いて，セッターが上げたトスの，0.3秒先のボールの2次元的な位置を予測するシステムを開発しました．Kinectを用いてセッターの動作時の三次元骨格座標を測定し，この情報を時系列順に並べたデータセットを入力として用いています．結果として，0.3秒先のボールの画像平面内での座標が出力されます．

これを応用し，ニューラルネットワークに入力する骨格部位を，腕部分のみや下半身のみに限定することで，トス動作の特徴が顕著に表れている身体部位を特定できることを示しました．

さらに，三次元情報ではなく，セッターの側面から見た二次元骨格座標を入力として用いても，適切にトス軌跡予測が行えることも示しました．これには画像から人の骨格座標を推定できるOpenPoseというライブラリを使い二次元情報を取得しています．これにより，一般的な試合映像からでも推定できる可能性を示しました．

今後は，より実用性の高いシステムへと改善し，オリンピック等の世界大会での実応用を目指しています．

<iframe width="500" height="281" src="https://www.youtube.com/embed/tqnvM2L86-I" title="Prediction of Volleyball Trajectory Using Skeletal Motions of Setter Player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>

国際学会で発表：[Shuya Suda, Yasutoshi Makino, Hiroyuki Shinoda, “Prediction of Volleyball Trajectory Using Skeletal Motions of Setter Player,” In AH 2019 Proceedings of the 10th Augmented Human International Conference 2019.](https://dl.acm.org/citation.cfm?id=3311844)
</file>

