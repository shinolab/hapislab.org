<file path="src/components/Members.astro">
---
import { getMembers, processMembers, type DegreeKey } from "../lib/members";
import { asRootRelativePath, withBasePath } from "../lib/urls";

interface Props {
	locale?: "ja" | "en";
}

const { locale = "ja" } = Astro.props;

const rawData = getMembers();
const { staff, activeStudents, alumniYears, alumniByYear } =
	processMembers(rawData);

const labels: Record<string, any> =
	locale === "en"
		? {
				staff: "Members",
				students: "Students",
				doctor: "Doctoral Students",
				master: "Master's Students",
				bachelor: "Undergraduate Students",
				alumni: "Alumni",
				thesis: "Thesis",
				email: "Email",
				fy: (year: number) => `FY ${year}`,
			}
		: {
				staff: "教職員・研究員",
				students: "学生",
				doctor: "博士課程",
				master: "修士課程",
				bachelor: "学部生",
				alumni: "卒業生・修了生",
				thesis: "論文題目",
				email: "メールアドレス",
				fy: (year: number) => `${year}年度`,
			};

const formatThesis = (thesis?: string, thesisEn?: string) => {
	if (locale === "en") {
		return thesisEn || thesis || "";
	}
	if (thesis && thesisEn) return `${thesis} (${thesisEn})`;
	return thesis || thesisEn || "";
};

const resolveMemberHref = (href?: string) =>
	withBasePath(asRootRelativePath(href)) ?? href;
---

<div class="content-stack">
	{}
	{
		staff.length > 0 && (
			<section class="legacy-block">
				<h3 class="legacy-block__title">{labels.staff}</h3>
				<div class="surface surface--table table-wrapper">
					<table class="legacy-data-table">
						<tbody>
							{staff.map((s) => (
								<tr>
									<td style="width: 25%;">
										{locale === "en"
											? s.roleEn || s.role
											: s.role}
									</td>
									<td style="width: 30%;">
										{resolveMemberHref(s.href) ? (
											<a href={resolveMemberHref(s.href)}>
												{locale === "en"
													? s.nameEn || s.name
													: s.name}
											</a>
										) : locale === "en" ? (
											s.nameEn || s.name
										) : (
											s.name
										)}
									</td>
									<td>{s.email}</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</section>
		)
	}

	{}
	<section class="legacy-block">
		<h3 class="legacy-block__title">{labels.students}</h3>

		{
			(["D", "M", "B"] as DegreeKey[]).map((dk) => {
				const students = activeStudents[dk];
				if (students.length === 0) return null;
				return (
					<div class="student-group">
						<h4>
							{
								labels[
									dk === "D"
										? "doctor"
										: dk === "M"
											? "master"
											: "bachelor"
								]
							}
						</h4>
						<div class="surface surface--table table-wrapper">
							<table class="legacy-data-table">
								<tbody>
									{students.map((st) => (
										<tr>
											<td style="width: 30%;">
												{resolveMemberHref(st.href) ? (
													<a
														href={resolveMemberHref(
															st.href,
														)}
													>
														{locale === "en"
															? st.nameEn ||
																st.name
															: st.name}
													</a>
												) : locale === "en" ? (
													st.nameEn || st.name
												) : (
													st.name
												)}
											</td>
											<td>{st.email}</td>
										</tr>
									))}
								</tbody>
							</table>
						</div>
					</div>
				);
			})
		}
	</section>

	{}
	{
		alumniYears.length > 0 && (
			<section class="legacy-block">
				<h3 class="legacy-block__title">{labels.alumni}</h3>
				{alumniYears.map((year) => (
					<div class="alumni-year">
						<h4>{labels.fy(year)}</h4>
						<div class="surface surface--table table-wrapper">
							<table class="legacy-data-table">
								<tbody>
									{alumniByYear[year].map((al) => (
										<tr>
											<td style="width: 15%;">
												{locale === "en"
													? al.roleEn
													: al.role}
											</td>
											<td style="width: 20%;">
												{resolveMemberHref(al.href) ? (
													<a
														href={resolveMemberHref(
															al.href,
														)}
													>
														{locale === "en"
															? al.nameEn ||
																al.name
															: al.name}
													</a>
												) : locale === "en" ? (
													al.nameEn || al.name
												) : (
													al.name
												)}
											</td>
											<td>
												{formatThesis(
													al.thesis,
													al.thesisEn,
												)}
											</td>
										</tr>
									))}
								</tbody>
							</table>
						</div>
					</div>
				))}
			</section>
		)
	}
</div>

<style>
	.student-group,
	.alumni-year {
		margin-bottom: 1.25rem;
