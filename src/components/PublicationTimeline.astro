---
import type { Publication } from "../lib/site-data";

interface Props {
	publications: Publication[];
	locale?: "ja" | "en";
}

const { publications, locale = "ja" } = Astro.props;

const groupedPublications = Array.from(
	publications.reduce((groups, publication) => {
		const collection = groups.get(publication.year) ?? [];
		collection.push(publication);
		groups.set(publication.year, collection);
		return groups;
	}, new Map<number, Publication[]>()),
).sort(([left], [right]) => right - left);
---

<section class="content-section">
	<div class="content-stack">
		{
			groupedPublications.map(([year, items]) => (
				<section class="legacy-block">
					<h3 class="legacy-block__title">{year}</h3>
					<div class="surface surface--table table-wrapper">
						<table class="legacy-data-table legacy-data-table--publications">
							<tbody>
								{items.map((publication) => (
									<tr>
										<td>{publication.title}</td>
									</tr>
								))}
							</tbody>
						</table>
					</div>
				</section>
			))
		}
	</div>
</section>
