---
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import type { ResearchTopicListItem } from "../lib/research-topics";
import { withBasePath } from "../lib/urls";

interface Props {
	topic: ResearchTopicListItem;
	title: string;
	description: string;
	currentPath: string;
	locale?: "ja" | "en";
	languageSwitchHref?: string;
	ContentComponent?: AstroComponentFactory;
	htmlContent?: string;
	fallbackNotice?: string;
	previousTopic?: ResearchTopicListItem;
	nextTopic?: ResearchTopicListItem;
	relatedTopics: ResearchTopicListItem[];
	shareUrl: string;
}

const {
	topic,
	title,
	description,
	currentPath,
	locale = "ja",
	languageSwitchHref,
	ContentComponent,
	htmlContent = "",
	fallbackNotice,
	previousTopic,
	nextTopic,
	relatedTopics,
	shareUrl,
} = Astro.props;

const articleDate = topic.date ?? topic.updated ?? "";
const dateObject = articleDate ? new Date(articleDate) : undefined;
const articleYear =
	dateObject && !Number.isNaN(dateObject.getTime())
		? String(dateObject.getFullYear())
		: "";
const articleMonthDay =
	dateObject && !Number.isNaN(dateObject.getTime())
		? `${dateObject.getMonth() + 1}/${dateObject.getDate()}`
		: "";

const publishedLabel = locale === "en" ? "Published: " : "公開日: ";
const updatedLabel = locale === "en" ? "Updated: " : "更新日: ";
const relatedHeading = locale === "en" ? "Related topics" : "関連記事";
const previousLabel = locale === "en" ? "Previous article" : "前の記事";
const nextLabel = locale === "en" ? "Next article" : "次の記事";
const copyLabel = locale === "en" ? "Copy URL" : "URLをコピー";
const pageTitle = `${title} | ${locale === "en" ? "Shinoda & Makino Lab" : "篠田・牧野研究室"}`;
const encodedTitle = encodeURIComponent(title);
const encodedUrl = encodeURIComponent(shareUrl);
const shareLinks = [
	{
		label: "X",
		href: `https://twitter.com/intent/tweet?text=${encodedTitle}&url=${encodedUrl}`,
		className: "topic-article-share__link topic-article-share__link--x",
	},
	{
		label: "Facebook",
		href: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
		className:
			"topic-article-share__link topic-article-share__link--facebook",
	},
	{
		label: "Hatena",
		href: `https://b.hatena.ne.jp/entry/${shareUrl.replace(/^https?:\/\//, "")}`,
		className:
			"topic-article-share__link topic-article-share__link--hatena",
	},
	{
		label: "Pocket",
		href: `https://getpocket.com/edit?url=${encodedUrl}&title=${encodedTitle}`,
		className:
			"topic-article-share__link topic-article-share__link--pocket",
	},
	{
		label: "LINE",
		href: `https://social-plugins.line.me/lineit/share?url=${encodedUrl}`,
		className: "topic-article-share__link topic-article-share__link--line",
	},
];
const relatedTopicsWithAssets = relatedTopics.map((relatedTopic) => ({
	topic: relatedTopic,
	imageSrc: relatedTopic.image,
}));
---

<Layout
	title={pageTitle}
	description={description}
	currentPath={currentPath}
	locale={locale}
	languageSwitchHref={languageSwitchHref}
>
	<head>
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/katex.min.css"
			integrity="sha384-/L6i+LN3dyoaK2jYG5ZLh5u13cjdsPDcFOSNJeFBFa/KgVXR5kOfTdiN3ft1uMAq"
			crossorigin="anonymous"
		/>
	</head>

	<div class="page-shell page-shell--research-topic-article">
		<section class="topic-article-hero">
			<div class="container topic-article-hero__inner">
				<div class="topic-article-hero__date" aria-hidden="true">
					{
						articleYear && (
							<span class="topic-article-hero__year">
								{articleYear}
							</span>
						)
					}
					{
						articleMonthDay && (
							<span class="topic-article-hero__month-day">
								{articleMonthDay}
							</span>
						)
					}
				</div>

				<div class="topic-article-hero__body">
					<h1>{title}</h1>
				</div>
			</div>
		</section>

		<main class="container page-main topic-article-main">
			<div class="content-stack topic-article-stack">
				{
					fallbackNotice && (
						<aside class="surface notice-card" role="note">
							<p>{fallbackNotice}</p>
						</aside>
					)
				}

				<article class="prose topic-article-content">
					{
						ContentComponent ? (
							<ContentComponent />
						) : (
							<Fragment set:html={htmlContent} />
						)
					}
				</article>

				<p class="topic-article-content-meta">
					<span>{publishedLabel}</span>
					<span
						>{
							topic.date ??
								(locale === "en" ? "Not set" : "未設定")
						}</span
					>
					<span class="topic-article-content-meta__separator">/</span>
					<span>{updatedLabel}</span>
					<span>
						{
							topic.updated ??
								topic.date ??
								(locale === "en" ? "Not set" : "未設定")
						}
					</span>
				</p>

				<section
					class="topic-article-share"
					aria-labelledby="topic-share-heading"
				>
					<div class="topic-article-share__actions">
						{
							shareLinks.map((item) => (
								<a
									class={item.className}
									href={item.href}
									target="_blank"
									rel="noreferrer"
								>
									{item.label}
								</a>
							))
						}

						<button
							type="button"
							class="topic-article-share__link topic-article-share__link--copy"
							data-copy-url={shareUrl}
							data-copy-default={copyLabel}
							data-copy-success={locale === "en"
								? "Copied"
								: "コピーしました"}
						>
							{copyLabel}
						</button>
					</div>
				</section>

				{
					(previousTopic || nextTopic) && (
						<nav
							class="topic-article-pagination"
							aria-label={
								locale === "en"
									? "Article navigation"
									: "記事ナビゲーション"
							}
						>
							{previousTopic ? (
								<a
									class="topic-article-pagination__item"
									href={withBasePath(
										(locale === "en"
											? previousTopic.detailPathEn
											: previousTopic.detailPath) ?? "#",
									)}
								>
									<span class="topic-article-pagination__label">
										{previousLabel}
									</span>
									<strong>
										{locale === "en"
											? (previousTopic.titleEn ??
												previousTopic.title)
											: previousTopic.title}
									</strong>
								</a>
							) : (
								<div />
							)}

							{nextTopic ? (
								<a
									class="topic-article-pagination__item topic-article-pagination__item--next"
									href={withBasePath(
										(locale === "en"
											? nextTopic.detailPathEn
											: nextTopic.detailPath) ?? "#",
									)}
								>
									<span class="topic-article-pagination__label">
										{nextLabel}
									</span>
									<strong>
										{locale === "en"
											? (nextTopic.titleEn ??
												nextTopic.title)
											: nextTopic.title}
									</strong>
								</a>
							) : (
								<div />
							)}
						</nav>
					)
				}

				<section
					class="topic-article-related"
					aria-labelledby="topic-related-heading"
				>
					<div class="section-heading section-heading--legacy">
						<h2 id="topic-related-heading">{relatedHeading}</h2>
					</div>

					<div class="legacy-topic-grid topic-article-related__grid">
						{
							relatedTopicsWithAssets.map(
								({ topic: relatedTopic, imageSrc }) => (
									<article class="topic-card topic-card--legacy">
										<a
											class="topic-card__link"
											href={withBasePath(
												(locale === "en"
													? relatedTopic.detailPathEn
													: relatedTopic.detailPath) ??
													"#",
											)}
										>
											<Image
												class="topic-card__image"
												src={imageSrc}
												alt={
													relatedTopic.imageAlt ??
													(locale === "en"
														? (relatedTopic.titleEn ??
															relatedTopic.title)
														: relatedTopic.title)
												}
												loading="lazy"
												width={400}
												height={300}
											/>

											<p class="topic-card__date">
												{relatedTopic.date}
											</p>
											<h3>
												{locale === "en"
													? (relatedTopic.titleEn ??
														relatedTopic.title)
													: relatedTopic.title}
											</h3>
										</a>
									</article>
								),
							)
						}
					</div>
				</section>
			</div>
		</main>
	</div>
</Layout>

<script>
	document
		.querySelectorAll<HTMLButtonElement>("[data-copy-url]")
		.forEach((button) => {
			button.addEventListener("click", async () => {
				const copyUrl = button.dataset.copyUrl;
				if (!copyUrl) return;

				await navigator.clipboard.writeText(copyUrl);
				button.textContent =
					button.dataset.copySuccess ?? button.textContent;

				window.setTimeout(() => {
					button.textContent =
						button.dataset.copyDefault ?? button.textContent;
				}, 1600);
			});
		});
</script>
