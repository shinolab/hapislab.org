---
import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import type { ResearchTopicListItem } from "../lib/research-topics";
import { withBasePath } from "../lib/urls";

interface Props {
    topic: ResearchTopicListItem;
    title: string;
    description: string;
    currentPath: string;
    locale?: "ja" | "en";
    languageSwitchHref?: string;
    ContentComponent?: AstroComponentFactory;
    htmlContent?: string;
    fallbackNotice?: string;
    previousTopic?: ResearchTopicListItem;
    nextTopic?: ResearchTopicListItem;
    relatedTopics: ResearchTopicListItem[];
}

const {
    topic,
    title,
    description,
    currentPath,
    locale = "ja",
    languageSwitchHref,
    ContentComponent,
    htmlContent = "",
    fallbackNotice,
    previousTopic,
    nextTopic,
    relatedTopics,
} = Astro.props;

const articleDate = topic.date ?? topic.updated ?? "";
const dateObject = articleDate ? new Date(articleDate) : undefined;
const articleYear =
    dateObject && !Number.isNaN(dateObject.getTime())
        ? String(dateObject.getFullYear())
        : "";
const articleMonthDay =
    dateObject && !Number.isNaN(dateObject.getTime())
        ? `${dateObject.getMonth() + 1}/${dateObject.getDate()}`
        : "";

const publishedLabel = locale === "en" ? "Published: " : "公開日: ";
const updatedLabel = locale === "en" ? "Updated: " : "更新日: ";
const relatedHeading = locale === "en" ? "Related topics" : "関連記事";
const previousLabel = locale === "en" ? "Previous article" : "前の記事";
const nextLabel = locale === "en" ? "Next article" : "次の記事";
const pageTitle = `${title} | ${locale === "en" ? "Shinoda & Makino Lab" : "篠田・牧野研究室"}`;
const relatedTopicsWithAssets = relatedTopics.map((relatedTopic) => ({
    topic: relatedTopic,
    imageSrc: relatedTopic.image,
}));
---

<Layout
    title={pageTitle}
    description={description}
    currentPath={currentPath}
    locale={locale}
    languageSwitchHref={languageSwitchHref}
>
    <head>
        <link
            rel="stylesheet"
            href="https://cdn.jsdelivr.net/npm/katex@0.16.38/dist/katex.min.css"
            integrity="sha384-/L6i+LN3dyoaK2jYG5ZLh5u13cjdsPDcFOSNJeFBFa/KgVXR5kOfTdiN3ft1uMAq"
            crossorigin="anonymous"
        />
    </head>

    <div class="page-shell page-shell--research-topic-article">
        <section class="topic-article-hero">
            <div class="container topic-article-hero__inner">
                <div class="topic-article-hero__date" aria-hidden="true">
                    {
                        articleYear && (
                            <span class="topic-article-hero__year">
                                {articleYear}
                            </span>
                        )
                    }
                    {
                        articleMonthDay && (
                            <span class="topic-article-hero__month-day">
                                {articleMonthDay}
                            </span>
                        )
                    }
                </div>

                <div class="topic-article-hero__body">
                    <h1>{title}</h1>
                </div>
            </div>
        </section>

        <main class="container page-main topic-article-main">
            <div class="content-stack topic-article-stack">
                {
                    fallbackNotice && (
                        <aside class="surface notice-card" role="note">
                            <p>{fallbackNotice}</p>
                        </aside>
                    )
                }

                <article class="prose topic-article-content">
                    {
                        ContentComponent ? (
                            <ContentComponent />
                        ) : (
                            <Fragment set:html={htmlContent} />
                        )
                    }
                </article>

                <p class="topic-article-content-meta">
                    <span>{publishedLabel}</span>
                    <span
                        >{
                            topic.date ??
                                (locale === "en" ? "Not set" : "未設定")
                        }</span
                    >
                    <span class="topic-article-content-meta__separator">/</span>
                    <span>{updatedLabel}</span>
                    <span>
                        {
                            topic.updated ??
                                topic.date ??
                                (locale === "en" ? "Not set" : "未設定")
                        }
                    </span>
                </p>

                {
                    (previousTopic || nextTopic) && (
                        <nav
                            class="topic-article-pagination"
                            aria-label={
                                locale === "en"
                                    ? "Article navigation"
                                    : "記事ナビゲーション"
                            }
                        >
                            {previousTopic ? (
                                <a
                                    class="topic-article-pagination__item"
                                    href={withBasePath(
                                        (locale === "en"
                                            ? previousTopic.detailPathEn
                                            : previousTopic.detailPath) ?? "#",
                                    )}
                                >
                                    <span class="topic-article-pagination__label">
                                        {previousLabel}
                                    </span>
                                    <strong>{previousTopic.title}</strong>
                                </a>
                            ) : (
                                <div />
                            )}

                            {nextTopic ? (
                                <a
                                    class="topic-article-pagination__item topic-article-pagination__item--next"
                                    href={withBasePath(
                                        (locale === "en"
                                            ? nextTopic.detailPathEn
                                            : nextTopic.detailPath) ?? "#",
                                    )}
                                >
                                    <span class="topic-article-pagination__label">
                                        {nextLabel}
                                    </span>
                                    <strong>{nextTopic.title}</strong>
                                </a>
                            ) : (
                                <div />
                            )}
                        </nav>
                    )
                }

                <section
                    class="topic-article-related"
                    aria-labelledby="topic-related-heading"
                >
                    <div class="section-heading section-heading--legacy">
                        <h2 id="topic-related-heading">{relatedHeading}</h2>
                    </div>

                    <div class="legacy-topic-grid topic-article-related__grid">
                        {
                            relatedTopicsWithAssets.map(
                                ({ topic: relatedTopic, imageSrc }) => (
                                    <article class="topic-card topic-card--legacy">
                                        <a
                                            class="topic-card__link"
                                            href={withBasePath(
                                                (locale === "en"
                                                    ? relatedTopic.detailPathEn
                                                    : relatedTopic.detailPath) ??
                                                    "#",
                                            )}
                                        >
                                            <Image
                                                class="topic-card__image"
                                                src={imageSrc}
                                                alt={
                                                    relatedTopic.imageAlt ??
                                                    relatedTopic.title
                                                }
                                                loading="lazy"
                                                width={400}
                                                height={300}
                                            />

                                            <p class="topic-card__date">
                                                {relatedTopic.date}
                                            </p>
                                            <h3>{relatedTopic.title}</h3>
                                        </a>
                                    </article>
                                ),
                            )
                        }
                    </div>
                </section>
            </div>
        </main>
    </div>
</Layout>

<style>
    .page-shell--research-topic-article .page-main {
        max-width: 1120px;
    }

    .topic-article-main {
        padding-top: 2rem;
    }

    .topic-article-stack {
        gap: 1.5rem;
    }

    .topic-article-hero {
        padding: 2rem 0 1rem;
    }

    .topic-article-hero__inner {
        display: grid;
        grid-template-columns: 5.5rem minmax(0, 1fr);
        max-width: 900px;
        margin: 0 auto;
        gap: 1rem;
        align-items: center;
        padding-left: 1.5rem;
        padding-right: 1.5rem;
    }

    .topic-article-hero__date {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.1rem;
        color: var(--text-subtle);
        text-align: center;
    }

    .topic-article-hero__year {
        font-size: 1.1rem;
        line-height: 1;
        letter-spacing: 0.08em;
    }

    .topic-article-hero__month-day {
        font-size: clamp(1rem, 2vw, 1.5rem);
        line-height: 1;
        font-weight: 700;
        color: var(--primary);
    }

    .topic-article-hero__body {
        display: grid;
        align-content: center;
        min-height: calc(1.1rem + 1.5rem + 0.1rem);
    }

    .topic-article-hero__body h1 {
        margin: 0;
        font-size: clamp(1.2rem, 1.6vw, 2rem);
        line-height: 1.2;
    }

    .topic-article-content {
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 2.2rem;
        background: #fff;
    }

    .topic-article-content :global(p) {
        margin-bottom: 2rem;
    }

    .topic-article-content :global(img),
    .topic-article-content :global(picture),
    .topic-article-content :global(video),
    .topic-article-content :global(iframe),
    .topic-article-content :global(svg),
    .topic-article-content :global(canvas) {
        max-width: 100%;
    }

    .topic-article-content :global(img),
    .topic-article-content :global(video),
    .topic-article-content :global(svg),
    .topic-article-content :global(canvas) {
        height: auto;
    }

    .topic-article-content :global(iframe) {
        width: 100%;
        display: block;
    }

    .topic-article-content > :global(p:first-child) > :global(img:only-child) {
        display: block;
        width: 100%;
        height: auto;
    }

    .topic-article-content :global(figure) {
        max-width: 100%;
        margin: 0 0 2rem;
    }

    .topic-article-content :global(.topic-article-inline-figure) {
        margin: 0 0 2rem;
    }

    .topic-article-content :global(.topic-article-inline-figure a) {
        display: block;
    }

    .topic-article-content :global(.topic-article-inline-figure img) {
        display: block;
        width: 100%;
        height: auto;
    }

    .topic-article-content :global(.topic-article-inline-figure figcaption) {
        margin-top: 0.75rem;
        color: var(--text-subtle);
        font-size: 0.95rem;
        line-height: 1.6;
        text-align: center;
    }

    .topic-article-content-meta {
        display: flex;
        justify-content: flex-end;
        flex-wrap: wrap;
        gap: 0.2rem 0.45rem;
        max-width: 900px;
        margin: -0.75rem auto 0;
        color: var(--text-subtle);
        font-size: 0.82rem;
    }

    .topic-article-content-meta__separator {
        opacity: 0.65;
    }

    .topic-article-pagination {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
        max-width: 900px;
        margin: 0 auto;
    }

    .topic-article-pagination__item {
        display: grid;
        gap: 0.35rem;
        padding: 1.2rem 1.3rem;
        border: 1px solid var(--border);
        background: #fff;
        color: inherit;
        text-decoration: none;
    }

    .topic-article-pagination__item--next {
        text-align: right;
    }

    .topic-article-pagination__label {
        color: var(--text-subtle);
        font-size: 0.84rem;
    }

    .topic-article-related {
        margin-top: 0.5rem;
    }

    .topic-article-related__grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1.5rem 1.1rem;
    }

    .topic-article-related .topic-card__date {
        margin-bottom: 0.3rem;
    }

    @media (max-width: 1024px) {
        .topic-article-hero__inner {
            grid-template-columns: 1fr;
        }

        .topic-article-hero__date {
            text-align: left;
        }

        .topic-article-content {
            padding: 1.5rem;
        }

        .topic-article-pagination {
            grid-template-columns: 1fr;
        }

        .topic-article-pagination__item--next {
            text-align: left;
        }
    }
</style>

<script>
    document
        .querySelectorAll<HTMLButtonElement>("[data-copy-url]")
        .forEach((button) => {
            button.addEventListener("click", async () => {
                const copyUrl = button.dataset.copyUrl;
                if (!copyUrl) return;

                await navigator.clipboard.writeText(copyUrl);
                button.textContent =
                    button.dataset.copySuccess ?? button.textContent;

                window.setTimeout(() => {
                    button.textContent =
                        button.dataset.copyDefault ?? button.textContent;
                }, 1600);
            });
        });
</script>
