---
import { awards as allAwards, type Award } from "../lib/awards";

interface Props {
	awards?: Award[];
	locale?: "ja" | "en";
	author?: string;
	className?: string;
}

const inferredLocale = Astro.url.pathname.startsWith("/en/") ? "en" : "ja";
const {
	awards: propsAwards,
	locale = inferredLocale,
	author,
	className,
} = Astro.props;

let filtered = propsAwards || allAwards;

if (author) {
	const searchNames = author
		.split("|")
		.map((n) => n.trim().toLowerCase())
		.filter(Boolean);
	filtered = filtered.filter((a) =>
		a.recipients.some((recipient) => {
			const normalizedRecipient = recipient
				.replace(/\s+/g, "")
				.toLowerCase();
			return searchNames.some((name) => {
				const normalizedName = name.replace(/\s+/g, "").toLowerCase();
				return normalizedRecipient.includes(normalizedName);
			});
		}),
	);
}

const formatMonthDay = (award: Award) =>
	award.month != null && award.day != null
		? `${award.month}/${award.day}`
		: null;

const labels =
	locale === "en"
		? {
				title: "Title",
			}
		: {
				title: "題目",
			};
---

<ul class:list={["award-list", className]}>
	{
		filtered.map((award) => (
			<li class="award-list__item surface surface--table table-wrapper">
				<table class="legacy-data-table">
					<tbody>
						<tr>
							<td style="width: 25%;">
								{formatMonthDay(award) && (
									<div class="award-date">
										{award.year}/{formatMonthDay(award)}
									</div>
								)}
								{!formatMonthDay(award) && (
									<div class="award-date">{award.year}</div>
								)}
								<div class="award-name">
									{award.href ? (
										<a
											href={award.href}
											target="_blank"
											rel="noopener noreferrer"
										>
											{award.award}
										</a>
									) : (
										award.award
									)}
								</div>
								{award.org && (
									<div class="award-org">
										<small>{award.org}</small>
									</div>
								)}
							</td>
							<td>
								<div class="award-recipients">
									<strong>
										{award.recipients.join(", ")}
									</strong>
									{award.external && (
										<span class="external-mark">*</span>
									)}
								</div>
								{award.title && (
									<div class="award-title">
										<span class="label">
											{labels.title}:
										</span>{" "}
										{award.title}
									</div>
								)}
							</td>
						</tr>
					</tbody>
				</table>
			</li>
		))
	}
</ul>

<style>
	.award-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}
	.award-list__item {
		padding: 0;
		margin: 0;
	}
	.award-org {
		color: var(--color-text-muted, #666);
		margin-top: 0.25rem;
	}
	.award-date {
		margin-bottom: 0.35rem;
		font-size: 0.85rem;
		font-weight: 700;
		color: var(--color-text-muted, #666);
	}
	.award-title {
		margin-top: 0.5rem;
		font-style: italic;
		font-size: 0.95rem;
	}
	.award-title .label {
		font-style: normal;
		font-weight: bold;
		font-size: 0.8rem;
		color: var(--color-text-muted, #666);
		text-transform: uppercase;
		margin-right: 0.25rem;
	}
	.legacy-data-table td {
		padding: 1rem 0.75rem;
		vertical-align: top;
		border-bottom: 0 !important;
	}
	.external-mark {
		color: var(--color-primary, #0056b3);
		font-weight: bold;
		margin-left: 0.25rem;
	}
</style>
