---
import { Image } from "astro:assets";

interface AssetLike {
	src: string;
	width?: number;
	height?: number;
}

interface Props {
	src: AssetLike | string;
	alt: string;
	width?: number;
	height?: number;
	loading?: "lazy" | "eager";
	sizes?: string;
	caption?: string;
	class?: string;
}

const {
	src,
	alt,
	width,
	height,
	loading = "lazy",
	sizes,
	caption,
	class: className = "",
} = Astro.props;

const imageUrl = typeof src === "string" ? src : src.src;
const dialogLabel = caption ? `${alt} - ${caption}` : alt;
const openLabel = `${alt} を拡大表示`;
---

<figure
	class:list={["mdx-lightbox", className]}
	data-mdx-lightbox
>
	<button
		type="button"
		class="mdx-lightbox__trigger"
		data-mdx-lightbox-open
		aria-label={openLabel}
	>
		{
			typeof src === "string" ? (
				<img
					src={imageUrl}
					alt={alt}
					width={width}
					height={height}
					loading={loading}
					class="mdx-lightbox__image"
				/>
			) : (
				<Image
					src={src}
					alt={alt}
					width={width}
					height={height}
					loading={loading}
					sizes={sizes}
					class="mdx-lightbox__image"
				/>
			)
		}
	</button>

	{caption && <figcaption class="mdx-lightbox__caption">{caption}</figcaption>}

	<dialog
		class="mdx-lightbox__dialog"
		data-mdx-lightbox-dialog
		aria-label={dialogLabel}
	>
		<div class="mdx-lightbox__dialog-inner">
			<button
				type="button"
				class="mdx-lightbox__close"
				data-mdx-lightbox-close
				aria-label="閉じる"
			>
				×
			</button>

			<img
				src={imageUrl}
				alt={alt}
				class="mdx-lightbox__full-image"
				loading="eager"
			/>

			{caption && <p class="mdx-lightbox__dialog-caption">{caption}</p>}
		</div>
	</dialog>
</figure>

<style>
	.mdx-lightbox {
		margin: 1.5rem 0;
	}

	.mdx-lightbox__trigger {
		display: block;
		max-width: 100%;
		margin: 0 auto;
		padding: 0;
		border: 0;
		background: none;
		cursor: zoom-in;
	}

	.mdx-lightbox__trigger :global(img),
	.mdx-lightbox__full-image {
		display: block;
		max-width: 100%;
		height: auto;
		border-radius: 0.5rem;
	}

	.mdx-lightbox__caption,
	.mdx-lightbox__dialog-caption {
		margin: 0.75rem 0 0;
		text-align: center;
		color: var(--text-subtle);
		font-size: 0.95rem;
	}

	.mdx-lightbox__dialog {
		width: min(92vw, 1100px);
		max-width: none;
		padding: 0;
		border: 0;
		border-radius: 0.75rem;
		background: transparent;
	}

	.mdx-lightbox__dialog::backdrop {
		background: rgba(9, 15, 21, 0.78);
		backdrop-filter: blur(2px);
	}

	.mdx-lightbox__dialog-inner {
		position: relative;
		padding: 3rem 1rem 1rem;
		border-radius: 0.75rem;
		background: rgba(19, 28, 36, 0.95);
		box-shadow: 0 1.25rem 3rem rgba(0, 0, 0, 0.35);
	}

	.mdx-lightbox__close {
		position: absolute;
		top: 0.75rem;
		right: 0.75rem;
		display: grid;
		place-items: center;
		width: 2.5rem;
		height: 2.5rem;
		border: 0;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.12);
		color: #fff;
		font-size: 1.5rem;
		line-height: 1;
		cursor: pointer;
	}

	.mdx-lightbox__close:hover,
	.mdx-lightbox__close:focus-visible {
		background: rgba(255, 255, 255, 0.2);
	}

	.mdx-lightbox__full-image {
		max-height: calc(100vh - 10rem);
		margin: 0 auto;
		object-fit: contain;
	}

	@media (max-width: 640px) {
		.mdx-lightbox__dialog {
			width: min(96vw, 1100px);
		}

		.mdx-lightbox__dialog-inner {
			padding-top: 3.5rem;
			padding-left: 0.75rem;
			padding-right: 0.75rem;
		}
	}
</style>

<script>
	function setupMdxLightboxes() {
		document
			.querySelectorAll<HTMLElement>("[data-mdx-lightbox]")
			.forEach((root) => {
				if (root.dataset.mdxLightboxReady === "true") {
					return;
				}

				const openButton = root.querySelector<HTMLButtonElement>(
					"[data-mdx-lightbox-open]",
				);
				const closeButton = root.querySelector<HTMLButtonElement>(
					"[data-mdx-lightbox-close]",
				);
				const dialog = root.querySelector<HTMLDialogElement>(
					"[data-mdx-lightbox-dialog]",
				);

				if (!openButton || !closeButton || !dialog) {
					return;
				}

				openButton.addEventListener("click", () => {
					dialog.showModal();
				});

				closeButton.addEventListener("click", () => {
					dialog.close();
				});

				dialog.addEventListener("click", (event) => {
					if (event.target === dialog) {
						dialog.close();
					}
				});

				root.dataset.mdxLightboxReady = "true";
			});
	}

	setupMdxLightboxes();
	document.addEventListener("astro:page-load", setupMdxLightboxes);
</script>
