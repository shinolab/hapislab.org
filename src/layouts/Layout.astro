---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { withBase } from "../lib/urls";
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
	currentPath?: string;
	locale?: "ja" | "en";
	languageSwitchHref?: string;
}

const {
	title = "篠田・牧野研究室",
	description = "システムの中に新しい物理現象や物理的構造を導入することで、従来の壁を越える実世界情報環境の実現を目指しています。",
	currentPath = "/",
	locale = "ja",
	languageSwitchHref,
} = Astro.props;

const backToTopLabel = locale === "en" ? "Back to top" : "ページ上部へ戻る";
---

<!doctype html>
<html lang={locale}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href={withBase("/favicon.ico")} sizes="any" />
		<link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body>
		<div class="site-shell" id="page-top">
			<Header
				currentPath={currentPath}
				locale={locale}
				languageSwitchHref={languageSwitchHref}
			/>
			<slot />
			<a
				class="back-to-top"
				href="#page-top"
				aria-label={backToTopLabel}
				aria-hidden="true"
				title={backToTopLabel}
				tabindex="-1"
				data-back-to-top
			>
				<span class="back-to-top__icon" aria-hidden="true"></span>
			</a>
			<Footer locale={locale} />
		</div>

		<script is:inline>
			(() => {
				const backToTop = document.querySelector("[data-back-to-top]");
				if (!(backToTop instanceof HTMLElement)) {
					return;
				}

				const syncVisibility = () => {
					const isVisible = window.scrollY > 320;
					backToTop.classList.toggle("is-visible", isVisible);
					backToTop.tabIndex = isVisible ? 0 : -1;
					backToTop.setAttribute("aria-hidden", String(!isVisible));
				};

				window.addEventListener("scroll", syncVisibility, {
					passive: true,
				});
				syncVisibility();
			})();
		</script>
	</body>
</html>
